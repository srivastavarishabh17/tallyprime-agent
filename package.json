{
  "name": "satyakiran-agent",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsx watch src/index.ts",
    "package:win": "npm run build && npx @yao-pkg/pkg . --targets node20-win-x64 --output AozoAgent.exe",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "outputPath": "release"
  },
  "dependencies": {
    "fast-xml-parser": "^5.2.5",
    "node-cron": "^4.2.1",
    "axios": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
